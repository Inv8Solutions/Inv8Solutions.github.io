{
  "extends": "@vue/tsconfig",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "postcss.config.mjs"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": [],

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
